APP_NAME=AdCraft
APP_VERSION=1.0.0
AGNO_MOCK_MODE=false
V2_PRODUCTION_ACCEPTANCE_ENABLED=false
SKIP_AUDIO_AGENTS=true
LLM_PROVIDER=siliconflow
LLM_API_KEY=
LLM_BASE_URL=https://api.siliconflow.cn/v1
LLM_TRANSIENT_RETRY_DELAY_SECONDS=2
LLM_FRONT_DESK_MODEL=zai-org/GLM-5.2
LLM_TEAM_MODEL=zai-org/GLM-5.2
LLM_REQUIREMENTS_MODEL=zai-org/GLM-5.2
LLM_PRODUCT_DESIGN_MODEL=zai-org/GLM-5.2
LLM_CREATIVE_MODEL=zai-org/GLM-5.2
