LLM_CHARACTER_MODEL=zai-org/GLM-5.2
LLM_SCENE_MODEL=zai-org/GLM-5.2
LLM_STORYBOARD_MODEL=zai-org/GLM-5.2
LLM_SOUND_EFFECTS_MODEL=zai-org/GLM-5.2
LLM_VOICEOVER_MODEL=zai-org/GLM-5.2
LLM_BGM_MODEL=zai-org/GLM-5.2
LLM_FINAL_VIDEO_MODEL=zai-org/GLM-5.2
MEDIA_MODE=real
IMAGE_GENERATION_API_KEY=
IMAGE_GENERATION_ENDPOINT=https://ark.cn-beijing.volces.com/api/v3/images/generations
IMAGE_GENERATION_MODEL=doubao-seedream-5-0-260128
IMAGE_GENERATION_SIZE=1920x1920
VIDEO_GENERATION_API_KEY=
VIDEO_GENERATION_ENDPOINT=https://ark.cn-beijing.volces.com/api/v3/contents/generations/tasks
VIDEO_GENERATION_MODEL=doubao-seedance-2-0-fast-260128
VIDEO_GENERATION_RESOLUTION=1080p
VIDEO_GENERATION_GENERATE_AUDIO=true
SOUND_EFFECTS_API_KEY=
SOUND_EFFECTS_ENDPOINT=
SOUND_EFFECTS_MODEL=
TTS_API_KEY=
TTS_ENDPOINT=
TTS_MODEL=
BGM_PROVIDER=tianpuyue
BGM_API_KEY=
BGM_ENDPOINT=https://api.tianpuyue.cn
BGM_MODEL=TemPolor i3
BGM_LONG_MODEL=TemPolor i3.5
BGM_CALLBACK_BASE_URL=
# Used only when BGM_PROVIDER=volcengine_ai_music
BGM_ACCESS_KEY_ID=
BGM_SECRET_ACCESS_KEY=
BGM_SUBMIT_ACTION=GenBGMForTime
BGM_API_VERSION=2024-08-12
BGM_GENERATION_VERSION=v5.0
BGM_TIMEOUT_SECONDS=60
COMPOSITION_API_KEY=
COMPOSITION_ENDPOINT=
COMPOSITION_PROVIDER=ffmpeg
FFMPEG_PATH=ffmpeg
FFPROBE_PATH=ffprobe
FINAL_COMPOSITION_SUBTITLE_FONT_PATH=
